PORT=4000
NODE_ENV=development
STACKS_NETWORK=testnet
CONTRACT_ADDRESS=ST000000000000000000002AMW42H
STACKS_API_URL=https://api.testnet.hiro.so

# sBTC SIP-010 asset identifier for on-chain escrow event verification.
# Testnet default: deploy a SIP-010 mock as .sbtc-token in the same deployer namespace.
# Mainnet: SM3VDXK3WZZSA84XXFKAFAF15NNZX32CTSG82JFQ4.sbtc-token::sbtc
# SBTC_ASSET_IDENTIFIER=
# Allowed frontend origins for CORS (comma-separated)
# Example: https://bit-express-88r6.vercel.app,https://bit-express-q2cv.vercel.app
# Wildcard support: https://*.vercel.app
CORS_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:4000

# Paystack live/test secret for Ghana and Kenya mobile-money payouts
PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
# Optional dedicated secret for validating Paystack webhooks (defaults to PAYSTACK_SECRET_KEY)
PAYSTACK_WEBHOOK_SECRET=

# CinetPay credentials for supported francophone mobile-money payouts
CINETPAY_API_KEY=
CINETPAY_TRANSFER_PASSWORD=
CINETPAY_BASE_URL=https://client.cinetpay.com
CINETPAY_NOTIFY_URL=http://localhost:4000/api/webhooks/cinetpay/transfer
CINETPAY_LANG=en
# Shared secret used to validate CinetPay webhook signatures (x-cinetpay-signature or x-token)
CINETPAY_WEBHOOK_SECRET=

# Firestore — set USE_FIRESTORE=true to persist data across restarts.
# Requires GOOGLE_APPLICATION_CREDENTIALS or FIREBASE_SERVICE_ACCOUNT_JSON to be set.
USE_FIRESTORE=true

# Option 1: Google ADC credential file
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Option 2: Inline service account JSON (single line)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"..."}
